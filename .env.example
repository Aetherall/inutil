# Unity account credentials for Personal-license activation under wine.
# Copy to `.env` (gitignored) and fill in your OWN free Unity account.
# Used only by `unity-license` (tools/wine/activate-license.sh) to activate a
# machine-bound Personal seat for the wine prefix. Never committed.
#
# A free Unity Personal account is enough: https://id.unity.com (sign up),
# no paid seat or serial required.
USERNAME=you@example.com
PASSWORD=yourUnityPassword
